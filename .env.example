# Copy to .env and fill in your Supabase credentials
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Never expose a Supabase secret or service-role key in a VITE_ variable.

# Optional: analytics. Leave blank to disable -- the site works fine
# without these, they just won't track visits until you add real IDs.
VITE_GA_MEASUREMENT_ID=
VITE_META_PIXEL_ID=
